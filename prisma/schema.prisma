// =============================================================================
//  Educational Consultancy CMS — Database Schema
//
//  Design pillars:
//   - Everything visible on the frontend is editable from the admin panel.
//   - Fully relational, normalized.
//   - SEO-first: every public entity has an optional SeoMeta record.
//   - Slug system: canonical slug on parent; localized slug per translation.
//   - Workflow: DRAFT → SCHEDULED → PUBLISHED → ARCHIVED via `ContentStatus`.
//   - Soft delete: `deletedAt DateTime?` on all content; filtered at the
//     data-access layer (Prisma has no global soft-delete filter yet).
//   - Versioning: snapshot tables (`*Version`) on heavy editing surfaces.
//   - Multilingual-ready: per-entity `*Translation` tables keyed by
//     (entityId, locale). The canonical-locale fields live on the parent row
//     so the public site has a single fallback path; translations override.
//
//  Transitional notes:
//   - `Page.sections` (Json) and inlined SEO fields on Page exist alongside
//     the new relational `Page.sectionRows` + `SeoMeta` model while the
//     editor migration completes. See MIGRATION-STRATEGY.md.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
//  Enums
// -----------------------------------------------------------------------------

enum ContentStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum Locale {
  EN
  NE
  HI
  ZH
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  AUTHOR
  COUNSELOR
  VIEWER
}

enum SectionType {
  HERO
  RICH_TEXT
  CTA
  COUNTRY_GRID
  ELIGIBILITY
  VISA_RISK
  COURSE_PATHWAYS
  RESOURCE_LIST
  TESTIMONIALS
  STATS
  FAQ
  PROCESS_STEPS
  BLOG_FEED
  LEAD_FORM
  COMPONENT_LIST
  CUSTOM
}

enum NavLocation {
  HEADER
  HEADER_SECONDARY
  FOOTER
  MOBILE
}

enum FormFieldType {
  TEXT
  EMAIL
  PHONE
  TEXTAREA
  SELECT
  MULTISELECT
  CHECKBOX
  RADIO
  DATE
  FILE
  HIDDEN
  COUNTRY_PICKER
  COURSE_PICKER
  RICH_TEXT
}

enum ResourceType {
