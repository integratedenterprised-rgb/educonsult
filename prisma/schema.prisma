// =============================================================================
//  Identity & Audit
// =============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String
  passwordHash  String?
  role          UserRole  @default(EDITOR)
  avatarUrl     String?
  image         String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?

  // Security: brute-force protection. Reset to 0 on successful login.
  // `lockedUntil` is checked before bcrypt compare to fail closed.
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  // Bumped when the password is set. Used to invalidate JWTs minted before
  // the change (compared against the JWT `iat`).
  passwordChangedAt   DateTime?
  // Force re-login after server-side session revocation without touching the
  // password. Compared against JWT `iat` in the `jwt` callback.
  sessionsInvalidAt   DateTime?

  // NextAuth relations
  accounts Account[]
  sessions Session[]
  auditLogs AuditLog[] @relation("AuditActor")

  authorProfile Author?

  // Audit relations
  pagesCreated  Page[]            @relation("PageCreatedBy")
  pagesUpdated  Page[]            @relation("PageUpdatedBy")
  postsCreated  BlogPost[]        @relation("PostCreatedBy")
  postsUpdated  BlogPost[]        @relation("PostUpdatedBy")
  pageVersions  PageVersion[]
  postVersions  BlogPostVersion[]
  assignedLeads LeadSubmission[]  @relation("LeadAssignedTo")

  // Lead CRM audit relations
  leadNotes              LeadNote[]     @relation("LeadNoteAuthor")
  leadFollowUpsAssigned  LeadFollowUp[] @relation("LeadFollowUpAssignee")
  leadFollowUpsCompleted LeadFollowUp[] @relation("LeadFollowUpCompletedBy")
  leadActivities         LeadActivity[] @relation("LeadActivityActor")
  leadMessagesSent       LeadMessage[]  @relation("LeadMessageTriggeredBy")

  // Analytics
  analyticsEvents AnalyticsEvent[] @relation("AnalyticsUser")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

// =============================================================================
//  NextAuth — auth provider tables (Account, Session, VerificationToken)
//
//  Required by `@auth/prisma-adapter`. Do not edit field names.
// =============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================================
//  Media library — uploaded files (managed via S3-compatible store)
// =============================================================================

model Media {
  id           String  @id @default(cuid())
  key          String  @unique // S3 object key
  url          String // public or signed URL base
  filename     String
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  alt          String?
  caption      String?
  folder       String? @default("uploads")
  uploadedById String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([folder])
  @@index([mimeType])
  @@index([deletedAt])
}

// =============================================================================
//  SEO — shared 1:1 with every public entity
// =============================================================================

model SeoMeta {
  id              String  @id @default(cuid())
  canonicalUrl    String?
  robots          String? @default("index,follow")
  ogImageUrl      String?
  twitterCardType String? @default("summary_large_image")
  structuredData  Json? // JSON-LD blob

  translations SeoMetaTranslation[]

  // Back-references (only one populated per record).
  page      Page?
  post      BlogPost?
  country   Country?
  category  Category?
  resource  Resource?
  pathway   CoursePathway?
  course    Course?
  prPathway PrPathway?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SeoMetaTranslation {
  id            String  @id @default(cuid())
  seoId         String
  seo           SeoMeta @relation(fields: [seoId], references: [id], onDelete: Cascade)
  locale        Locale
  title         String
  description   String?
  keywords      String?
  ogTitle       String?
  ogDescription String?

  @@unique([seoId, locale])
}

// =============================================================================
//  Pages
// =============================================================================

model Page {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String // canonical-locale title; translations override
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  scheduledAt DateTime?
  template    String? // "home" | "landing" | "country" | …
  isHomepage  Boolean       @default(false)

  // Nestable URLs: /services/usa/undergraduate
  parentId String?
  parent   Page?   @relation("PageHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Page[]  @relation("PageHierarchy")

  // SEO — preferred path going forward
  seoId String?  @unique
  seo   SeoMeta? @relation(fields: [seoId], references: [id], onDelete: SetNull)

  // Relational sections — populated during the editor migration.
  // Bootstrap consumers continue to read/write `sections` (Json) below until
  // Phase 4 of MIGRATION-STRATEGY.md flips the page editor to the relational
  // model. At Phase 5, `sections` (Json) is dropped and `sectionRows` is
  // renamed to `sections`.
  sectionRows Section[]

  // Transitional inline fields kept until the relational editor migration completes.
  /// @deprecated — moving to SeoMeta. Stop reading after Phase 4.
  seoTitle       String?
  /// @deprecated — moving to SeoMeta.
  seoDescription String?
  /// @deprecated — moving to SeoMeta.
  seoKeywords    String?
  /// @deprecated — moving to SeoMeta.
  ogImageUrl     String?
  /// @deprecated — JSON sections. Backfilled then dropped in Phase 5.
  sections       Json    @default("[]")

  // i18n + versioning
  translations PageTranslation[]
  versions     PageVersion[]

  // Inverse relations — nav/footer items that link to this page
  navItems    NavItem[]
  footerLinks FooterLink[]

  // Analytics
  analyticsEvents AnalyticsEvent[]

  // Audit
  createdById String?
  createdBy   User?   @relation("PageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?   @relation("PageUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([parentId, slug])
  @@index([status, publishedAt])
  @@index([isHomepage])
  @@index([deletedAt])
}

model PageTranslation {
  id     String @id @default(cuid())
  pageId String
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  locale Locale

  title   String
  slug    String // locale-specific slug
  excerpt String?

  @@unique([pageId, locale])
  @@unique([locale, slug])
  @@index([locale])
}

model PageVersion {
  id         String  @id @default(cuid())
  pageId     String
  page       Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  version    Int
  snapshot   Json // full page + sections + translations at this revision
  changeNote String?

  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@unique([pageId, version])
  @@index([pageId, createdAt])
}

// =============================================================================
//  Sections — ordered blocks inside a Page
//
//  Discriminated by `type`. Type-specific data lives in:
//    - 1:1 relations for single-instance blocks (HeroSection, CtaBlock, LeadForm)
//    - M:N joins for collections (Countries, Testimonials, Resources, Pathways)
//    - Free-form `settings` JSON for layout/style flags
//
// =============================================================================

model Section {
  id        String      @id @default(cuid())
  pageId    String
  page      Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      SectionType
  order     Int
  isVisible Boolean     @default(true)
  anchor    String? // for #fragment links
  settings  Json? // paddingY, background, containerWidth, custom flags

  // 1:1 typed blocks (only the one matching `type` is populated)
  heroId String?      @unique
  hero   HeroSection? @relation(fields: [heroId], references: [id], onDelete: SetNull)

  ctaId String?   @unique
  cta   CtaBlock? @relation(fields: [ctaId], references: [id], onDelete: SetNull)

  formId String?
  form   LeadForm? @relation(fields: [formId], references: [id], onDelete: SetNull)

  // M:N collections
  countryCards SectionCountryCard[]
  testimonials SectionTestimonial[]
  resources    SectionResource[]
  pathways     SectionCoursePathway[]
  components   SectionComponent[]

  translations SectionTranslation[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([pageId, order])
  @@index([type])
}

model SectionTranslation {
  id         String  @id @default(cuid())
  sectionId  String
  section    Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  locale     Locale
  eyebrow    String?
  heading    String?
  subheading String?
  body       String?

  @@unique([sectionId, locale])
}

// =============================================================================
//  Components — global, reusable block library
// =============================================================================

model Component {
  id         String  @id @default(cuid())
  key        String  @unique // "feature-tile", "stat-counter", …
  name       String
  type       String // frontend renderer key
  props      Json // default props
  isReusable Boolean @default(true)

  sections     SectionComponent[]
  translations ComponentTranslation[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model ComponentTranslation {
  id          String    @id @default(cuid())
  componentId String
  component   Component @relation(fields: [componentId], references: [id], onDelete: Cascade)
  locale      Locale
  content     Json // localized props

  @@unique([componentId, locale])
}

model SectionComponent {
  id          String    @id @default(cuid())
  sectionId   String
  section     Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  componentId String
  component   Component @relation(fields: [componentId], references: [id], onDelete: Cascade)
  order       Int
  overrides   Json?

  @@unique([sectionId, componentId, order])
  @@index([sectionId, order])
}

// =============================================================================
//  Hero Sections
// =============================================================================

model HeroSection {
  id              String  @id @default(cuid())
  variant         String? // "split" | "centered" | "video-bg" | "carousel"
  backgroundImage String?
  backgroundVideo String?
  overlayOpacity  Float?  @default(0.4)
  primaryCtaUrl   String?
  secondaryCtaUrl String?

  section      Section?
  translations HeroSectionTranslation[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model HeroSectionTranslation {
  id                String      @id @default(cuid())
  heroId            String
  hero              HeroSection @relation(fields: [heroId], references: [id], onDelete: Cascade)
  locale            Locale
  eyebrow           String?
  headline          String
  subheadline       String?
  primaryCtaLabel   String?
  secondaryCtaLabel String?

  @@unique([heroId, locale])
}

// =============================================================================
//  Country Cards (Destinations)
// =============================================================================

model Country {
  id              String  @id @default(cuid())
  code            String  @unique // ISO 3166-1 alpha-2
  slug            String  @unique
  flagUrl         String?
  imageUrl        String?
  avgTuitionUsd   Int?
  visaSuccessRate Float?
  popularity      Int     @default(0)
  isFeatured      Boolean @default(false)

  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?

  seoId String?  @unique
  seo   SeoMeta? @relation(fields: [seoId], references: [id], onDelete: SetNull)

  translations CountryTranslation[]
  sectionCards SectionCountryCard[]
  pathways     CoursePathway[]
  visaRules    VisaRiskRule[]
  testimonials Testimonial[]

  // Career engine inverse relations
  courseMappings  CourseCountryMapping[]
  prPathways      PrPathway[]
  salaryEstimates SalaryEstimate[]
  demandSignals   DemandSignal[]
  careerTrends    CareerTrend[]

  // Analytics
  analyticsEvents AnalyticsEvent[] @relation("CountryAnalytics")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status, publishedAt])
  @@index([isFeatured, popularity])
  @@index([deletedAt])
}

model CountryTranslation {
  id          String  @id @default(cuid())
  countryId   String
  country     Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  locale      Locale
  name        String
  shortIntro  String?
  description String?

  @@unique([countryId, locale])
}

model SectionCountryCard {
  id        String  @id @default(cuid())
  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  countryId String
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  order     Int
  overrides Json? // per-instance label/accent overrides

  @@unique([sectionId, countryId])
  @@index([sectionId, order])
}

// =============================================================================
//  Testimonials
// =============================================================================

model Testimonial {
  id              String  @id @default(cuid())
  studentName     String
  studentPhotoUrl String?
  universityName  String?
  programName     String?
  intakeYear      Int?
  rating          Int? // 1..5
  isFeatured      Boolean @default(false)

  countryId String?
  country   Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)

  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?

  translations TestimonialTranslation[]
  sectionLinks SectionTestimonial[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status, publishedAt])
  @@index([isFeatured])
  @@index([deletedAt])
}

model TestimonialTranslation {
  id            String      @id @default(cuid())
  testimonialId String
  testimonial   Testimonial @relation(fields: [testimonialId], references: [id], onDelete: Cascade)
  locale        Locale
  quote         String
  studentTitle  String? // "MSc CS, MIT '25"

  @@unique([testimonialId, locale])
}

model SectionTestimonial {
  id            String      @id @default(cuid())
  sectionId     String
  section       Section     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  testimonialId String
  testimonial   Testimonial @relation(fields: [testimonialId], references: [id], onDelete: Cascade)
  order         Int

  @@unique([sectionId, testimonialId])
  @@index([sectionId, order])
}

// =============================================================================
//  CTA Blocks
// =============================================================================

model CtaBlock {
  id              String  @id @default(cuid())
  variant         String? // "banner" | "inline" | "card" | "split"
  backgroundImage String?
  backgroundColor String?
  primaryCtaUrl   String?
  secondaryCtaUrl String?

  section      Section?
  translations CtaBlockTranslation[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model CtaBlockTranslation {
  id                String   @id @default(cuid())
  ctaId             String
  cta               CtaBlock @relation(fields: [ctaId], references: [id], onDelete: Cascade)
  locale            Locale
  heading           String
  body              String?
  primaryCtaLabel   String?
  secondaryCtaLabel String?

  @@unique([ctaId, locale])
}

// =============================================================================
//  Blog
// =============================================================================

// Source format for the canonical body. Translations carry their own copy
// of the body — keep `bodyFormat` here as the editor hint that drives the
// renderer pick at request time.
enum BlogBodyFormat {
  HTML
  MDX
  LEXICAL_JSON
}

model BlogPost {
  id             String         @id @default(cuid())
  slug           String         @unique
  title          String // canonical title; translations override
  excerpt        String? // canonical excerpt; translations override
  body           String         @default("") // canonical-locale body; translations override
  bodyFormat     BlogBodyFormat @default(HTML)
  coverImageUrl  String?
  coverImageAlt  String?
  readingMinutes Int?
  wordCount      Int?
  isFeatured     Boolean        @default(false)
  /// Cached table-of-contents derived from body headings ([{id,text,level}]).
  /// Re-computed on every save; safe to read on the public path.
  toc            Json?

  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  scheduledAt DateTime?

  authorId String?
  author   Author? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  categories BlogPostCategory[]
  tags       BlogPostTag[]

  seoId String?  @unique
  seo   SeoMeta? @relation(fields: [seoId], references: [id], onDelete: SetNull)

  faqs          BlogPostFaq[]
  ctaSlots      BlogPostCta[]
  internalLinks BlogPostInternalLink[]
  // Manual related-post pins. When empty, related posts are computed at
  // read time from shared categories/tags (see blog.service.ts).
  relatedFrom   BlogPostRelated[]      @relation("RelatedSource")
  relatedTo     BlogPostRelated[]      @relation("RelatedTarget")

  translations BlogPostTranslation[]
  versions     BlogPostVersion[]

  // Analytics
  analyticsEvents AnalyticsEvent[] @relation("BlogPostAnalytics")

  createdById String?
  createdBy   User?   @relation("PostCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?
  updatedBy   User?   @relation("PostUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status, publishedAt])
  @@index([authorId])
  @@index([isFeatured])
  @@index([deletedAt])
}

// FAQ entries scoped to one post. Rendered after the body and emitted as
// FAQPage JSON-LD so Google can surface rich results for the post.
model BlogPostFaq {
  id       String   @id @default(cuid())
  postId   String
  post     BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  question String
  answer   String // markdown / plain text — renderer escapes
  order    Int      @default(0)

  translations BlogPostFaqTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, order])
}

model BlogPostFaqTranslation {
  id       String      @id @default(cuid())
  faqId    String
  faq      BlogPostFaq @relation(fields: [faqId], references: [id], onDelete: Cascade)
  locale   Locale
  question String
  answer   String

  @@unique([faqId, locale])
}

// CTA slots — admin-controlled call-to-action blocks injected into the post
// body at a chosen anchor or after a heading. Position rules let one piece
// of body content host different CTAs per post without editing the body.
enum BlogCtaPlacement {
  AFTER_INTRO // after the first paragraph
  AFTER_HEADING // after the heading whose id matches anchor
  END_OF_POST // appended after the body and before related posts
  SIDEBAR // floats in the sidebar on wide layouts
  AFTER_PARAGRAPH // after the Nth paragraph (see paragraphIndex)
}

enum BlogCtaVariant {
  INLINE
  CARD
  BANNER
  LEAD_FORM
}

model BlogPostCta {
  id              String           @id @default(cuid())
  postId          String
  post            BlogPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  placement       BlogCtaPlacement
  variant         BlogCtaVariant   @default(CARD)
  anchor          String? // heading id when placement = AFTER_HEADING
  paragraphIndex  Int? // 0-based when placement = AFTER_PARAGRAPH
  heading         String
  body            String?
  primaryLabel    String?
  primaryUrl      String?
  secondaryLabel  String?
  secondaryUrl    String?
  formKey         String? // when variant = LEAD_FORM, references LeadForm.key
