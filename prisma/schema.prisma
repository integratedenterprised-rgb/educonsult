  SENIOR
  LEAD
}

enum PrPathwayType {
  POST_STUDY_WORK
  GRADUATE_VISA
  SKILLED_INDEPENDENT
  EMPLOYER_SPONSORED
  REGIONAL
  EXPRESS_ENTRY
