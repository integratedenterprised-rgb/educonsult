  RESOURCE_DOWNLOAD
  CONTACT_FORM
  NEWSLETTER
  CHAT_WIDGET
  PHONE_CALL
  WALK_IN
  REFERRAL
  AGENT
  EVENT
  MANUAL_ENTRY
  IMPORT
  OTHER
}

enum LeadTemperature {
  HOT
