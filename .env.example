# ──────────────────────────────────────────────────────────────────────────────
# Runtime — validated by src/lib/env.ts at boot. Missing or malformed values
# will crash the process early so misconfiguration never reaches production.
# ──────────────────────────────────────────────────────────────────────────────

# Application
NODE_ENV="development"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Educational Consultancy"
NEXT_PUBLIC_DEFAULT_LOCALE="en"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/educational_consultancy?schema=public"
SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/educational_consultancy_shadow?schema=public"

# Auth (admin panel) — replace with real secret in production
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"

# Optional integrations
NEXT_PUBLIC_GA_ID=""
SENTRY_DSN=""

# CMS revalidation webhook (optional — for triggering ISR from admin saves)
REVALIDATE_SECRET=""
