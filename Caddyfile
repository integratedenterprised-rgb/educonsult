{
	email admin@aeroabroad.com.np
}

aeroabroad.com.np, www.aeroabroad.com.np {
	encode zstd gzip

	# Public media served from MinIO under /media/* so the site never exposes
	# the storage host directly and S3_PUBLIC_URL_BASE stays clean.
	@media path /media/*
	handle @media {
		uri strip_prefix /media
		reverse_proxy minio:9000 {
			header_up Host {upstream_hostport}
		}
	}

	# Everything else → Next.js
	reverse_proxy app:3000 {
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-For {remote_host}
		header_up X-Real-IP {remote_host}
	}

	# Belt-and-suspenders: Next sets these too, but Caddy guarantees them
	# even on error responses it generates itself.
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
