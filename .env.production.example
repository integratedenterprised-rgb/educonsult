# ──────────────────────────────────────────────────────────────────────────────
# Production env for docker-compose on 202.51.0.85.
#
# Copy to `.env.production` and fill in the placeholders. This file is read by
# docker-compose; the `app` service receives these via env_file. Never commit
# `.env.production`. The compose file ALSO consumes POSTGRES_* and MINIO_*
# from this file via `${VAR}` interpolation.
# ──────────────────────────────────────────────────────────────────────────────

# ── Public site identity ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://aeroabroad.com.np
NEXT_PUBLIC_SITE_NAME="Aero Abroad"
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_GA_ID=

# ── Postgres (compose service "db") ──────────────────────────────────────────
# These ALSO feed the docker-compose interpolation for the db service env.
POSTGRES_USER=aeroabroad
POSTGRES_DB=aeroabroad
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── MinIO (compose service "minio") ──────────────────────────────────────────
# Generate: openssl rand -hex 16  (user)  and  openssl rand -base64 32 (pass)
MINIO_ROOT_USER=REPLACE_WITH_MINIO_USER
MINIO_ROOT_PASSWORD=REPLACE_WITH_MINIO_PASSWORD
S3_BUCKET=media

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=REPLACE_WITH_AUTH_SECRET
AUTH_URL=https://aeroabroad.com.np
AUTH_TRUST_HOST=true

# ── Email (optional, for password resets / lead notifications) ───────────────
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=

# ── Observability (optional) ─────────────────────────────────────────────────
SENTRY_DSN=

# ── ISR revalidation webhook (optional) ──────────────────────────────────────
REVALIDATE_SECRET=

# ── Security ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://aeroabroad.com.np,https://www.aeroabroad.com.np
TRUSTED_PROXY_HOPS=1
